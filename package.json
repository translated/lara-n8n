{
  "name": "n8n-nodes-lara-translate",
  "version": "1.1.3",
  "description": "n8n community node for translating text and documents with Lara Translate API",
  "keywords": [
    "n8n-community-node-package",
    "lara",
    "translate",
    "translated"
  ],
  "license": "MIT",
  "homepage": "https://laratranslate.com",
  "author": {
    "name": "Lara Translate",
    "email": "gtm@laratranslate.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/translated/lara-n8n"
  },
  "engines": {
    "node": ">=20.15"
  },
  "scripts": {
    "build": "npx rimraf dist && tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "pnpm run build && npx eslint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/LaraTranslateApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/LaraTranslate/LaraTranslate.node.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@typescript-eslint/parser": "~8.59.0",
    "@vitest/coverage-v8": "^3.0.5",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.3",
    "gulp": "^5.0.0",
    "link": "^2.1.1",
    "n8n-workflow": "*",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "typescript": "5.8.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "packageManager": "pnpm@10.18.2",
  "pnpm": {
    "overrides": {
      "axios@>=1.0.0 <1.12.0": "^1.12.0",
      "form-data@>=4.0.0 <4.0.4": "^4.0.4",
      "glob@>=11.0.0 <11.1.0": "^11.1.0",
      "@isaacs/brace-expansion@<=5.0.0": "^5.0.1",
      "minimatch@<3.1.4": "^3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "^10.2.3",
      "flatted@<=3.4.1": "^3.4.2",
      "lodash@<=4.17.23": "^4.18.0",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "rollup@>=4.0.0 <4.59.0": "^4.59.0",
      "vite@>=7.0.0 <=7.3.1": "^7.3.2",
      "postcss@<8.5.10": "^8.5.10",
      "ajv@<6.14.0": "^6.14.0",
      "js-yaml@>=4.0.0 <4.1.1": "^4.1.1",
      "brace-expansion@<1.1.13": "^1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "^2.0.3"
    }
  }
}
